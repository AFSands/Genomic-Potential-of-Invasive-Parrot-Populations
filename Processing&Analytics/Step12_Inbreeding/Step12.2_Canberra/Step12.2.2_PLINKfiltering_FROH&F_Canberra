#################################################
# NOTES: This script was run in an interactive node. The inputs are taken from Step12.2.1.
#################################################

module load plink/1.90b7.7

#LD pruning
plink --tfile CanROH_2 --make-bed --allow-extra-chr --missing --recode --out CanROH_2 #SNPs 1,576,678
plink --bfile CanROH_2 --allow-extra-chr --indep-pairwise 50 5 0.2 --out CanROH_2
plink --bfile CanROH_2 --allow-extra-chr --extract CanROH_2.prune.in --make-bed --distance triangle ibs 1-ibs allele-ct --out CanROH_2_LDprune  

#ROH/HET
plink --bfile CanROH_2_LDprune --allow-extra-chr --het --homozyg-kb 100 --homozyg-window-snp 25 --homozyg-window-threshold 0.05 --homozyg-window-het 2 --homozyg-density 50 --homozyg-window-missing 5 --homozyg-het 750 --out CanROH_2_LDprune_ROH #SNPs 108,570

#CurrentNe
plink --bfile CanROH_2_LDprune --allow-extra-chr --recode vcf --out CanROH_2_LDprune_currentNe #SNPs 108,570
