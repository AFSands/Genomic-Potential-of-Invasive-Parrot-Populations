#################################################
# NOTES: This script was repeated 10 times, each time from a separate subfolder listed A-J to generate 10 replicates of each K for each group. This script shown is for replicate "A". To adjust for other replicates, change "*_A.out" to "*_B.out", "*_C.out", etc.
#################################################

#!/bin/bash -l
#SBATCH --job-name=admix
#SBATCH --output=array_job_out_%A_%a.txt
#SBATCH --error=array_job_err_%A_%a.txt
#SBATCH --account=project_2006079
#SBATCH --partition=small
#SBATCH --time=72:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=10
#SBATCH --mem-per-cpu=12G

#Change permissions
chmod -R 777 *

#Run Admixture analyses Group 1
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group1/InvasiveRegions_Select_G1_LDprune.bed 2 -j10 > log_G1_2_A.out
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group1/InvasiveRegions_Select_G1_LDprune.bed 3 -j10 > log_G1_3_A.out

#Run Admixture analyses Group 2
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group2/InvasiveRegions_Select_G2_LDprune.bed 2 -j10 > log_G2_2_A.out
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group2/InvasiveRegions_Select_G2_LDprune.bed 3 -j10 > log_G2_3_A.out

#Run Admixture analyses Group 3
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group3/InvasiveRegions_Select_G3_LDprune.bed 2 -j10 > log_G3_2_A.out
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group3/InvasiveRegions_Select_G3_LDprune.bed 3 -j10 > log_G3_3_A.out

#Run Admixture analyses Group 4
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group4/InvasiveRegions_Select_G4_LDprune.bed 2 -j10 > log_G4_2_A.out
/projappl/project_2006079/afsands/dist/admixture_linux-1.3.0/admixture --cv -s time -B1000 /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step8_angsd/AdmixInvasives/Regions_select/Group4/InvasiveRegions_Select_G4_LDprune.bed 3 -j10 > log_G4_3_A.out

#Change permissions
chmod -R 777 *
