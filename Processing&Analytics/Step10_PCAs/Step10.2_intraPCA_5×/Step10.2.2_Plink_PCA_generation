#################################################
# NOTES: This script was run in an interactive node. The inputs are taken from Step10.2.1.
#################################################

#Load Plik 1.90
module load plink/1.90

#LD Pruning
plink --tfile Invasive5x_3 --make-bed --allow-extra-chr --missing --recode --out Invasive5x_3 #SNPs 47,724
plink --bfile Invasive5x_3 --allow-extra-chr --indep-pairwise 50 5 0.2 --out Invasive5x_3
plink --bfile Invasive5x_3 --allow-extra-chr --extract Invasive5x_3.prune.in --make-bed --distance triangle ibs 1-ibs allele-ct --out Invasive5x_3_ldprune_PCA #SNPs 30,155

#Load plink 2
module load plink

#PCA
plink2 --bfile Invasive5x_3_ldprune_PCA --pca 10 --allow-extra-chr --bad-freqs --out Invasive5x_3_ldprune_PCA #SNPs 30,155
