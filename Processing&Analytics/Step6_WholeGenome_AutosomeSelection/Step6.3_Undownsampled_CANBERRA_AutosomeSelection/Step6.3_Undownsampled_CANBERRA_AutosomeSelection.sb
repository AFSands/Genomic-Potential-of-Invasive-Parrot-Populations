#################################################
# NOTES: This script is run as an array job and requires a support file called "CBRlist" containing specimen BAM file names to run.
#################################################

#!/bin/bash -l
#SBATCH --job-name=RemoveSexContigs
#SBATCH --output=array_job_out_%A_%a.txt
#SBATCH --error=array_job_err_%A_%a.txt
#SBATCH --account=project_2006079
#SBATCH --partition=small
#SBATCH --time=72:00:00
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --mem-per-cpu=16G
#SBATCH --array=1-13

module load biokit

#set the input file to process
name=$(sed -n ${SLURM_ARRAY_TASK_ID}p CBRlist)

samtools view -h /scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/scratch/project_2006079/aDNA_AFS/project_2006079/aDNA/step6_MapDamage_WGcit/${name}/${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_finalsort.bam SUPER_1 SUPER_2 SUPER_3 SUPER_4 SUPER_5 SUPER_6 SUPER_7 SUPER_8 SUPER_9 SUPER_10 SUPER_11 SUPER_12 SUPER_13 SUPER_14 SUPER_15 SUPER_16 SUPER_17 SUPER_18 SUPER_19 SUPER_20 SUPER_21 SUPER_22 SUPER_23 SUPER_24 SUPER_25 SUPER_26 SUPER_27 SUPER_28 SUPER_29 SUPER_30 SUPER_31 SUPER_32 SUPER_33 SUPER_34 SUPER_35 SUPER_36 SUPER_37 SUPER_38 SUPER_39 | \
samtools view -Sb - > ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes.bam
samtools sort -m 16G -@ 8 -o ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes_finalsort.bam ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes.bam
samtools index ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes_finalsort.bam
samtools flagstat ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes_finalsort.bam > ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes_finalsort.bam.flagstat
samtools depth ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes_finalsort.bam | awk '{sum+=$3; sumsq+=$3*$3} END { print "Average = ",sum/NR; print "Stdev = ",sqrt(sumsq/NR - (sum/NR)**2)}' > coverage_${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes_finalsort.txt

rm ${name}_PEMEmerged_sort_RG_resort_Mkdup_sort_rescaled_sort_autosomes.bam
